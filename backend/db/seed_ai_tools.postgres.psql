INSERT INTO tool_categories (tool_id, category_id, is_primary)
SELECT t.id, c.id, TRUE
FROM tools t
JOIN categories c ON c.slug = 'music'
WHERE t.slug IN ('music-lyrics-0','music-mastering-23','music-mastering-37','music-lyrics-111','music-recommendations-137','music-lyrics-214','music-mixing-237','music-mixing-243','music-composition-282','music-lyrics-363','music-lyrics-402','music-mixing-410','music-recommendations-480','music-composition-621','music-mastering-672','music-lyrics-796','music-recommendations-797','music-mastering-822','music-mastering-924','music-mixing-957','music-composition-1042','music-recommendations-1114','music-mastering-1119','music-composition-1230','music-mixing-1272','music-composition-1283','music-mastering-1311','music-lyrics-1317','music-lyrics-1334','music-composition-1580','music-recommendations-1599','music-mastering-1651','music-mastering-1715','music-mixing-1818','music-composition-1853','music-mixing-1911','music-lyrics-1918','music-recommendations-1931','music-mixing-1951','music-lyrics-1952','music-lyrics-2023','music-mixing-2174','music-mixing-2302','music-mixing-2339','music-mixing-2415','music-mixing-2434')
