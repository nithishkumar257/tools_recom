INSERT INTO tool_categories (tool_id, category_id, is_primary)
SELECT t.id, c.id, TRUE
FROM tools t
JOIN categories c ON c.slug = 'coding'
WHERE t.slug IN ('github-copilot', 'codeium')
ON CONFLICT (tool_id, category_id) DO NOTHING;

INSERT INTO tool_categories (tool_id, category_id, is_primary)
SELECT t.id, c.id, TRUE
FROM tools t
JOIN categories c ON c.slug = 'writing'
WHERE t.slug = 'chatgpt'
ON CONFLICT (tool_id, category_id) DO NOTHING;

INSERT INTO tool_categories (tool_id, category_id, is_primary)
SELECT t.id, c.id, TRUE
FROM tools t
JOIN categories c ON c.slug = 'automation'
WHERE t.slug = 'n8n'
ON CONFLICT (tool_id, category_id) DO NOTHING;
