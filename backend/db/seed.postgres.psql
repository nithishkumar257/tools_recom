INSERT INTO categories (name, slug, description, sort_order)
VALUES
  ('Coding', 'coding', 'Code generation and code assistants', 1),
  ('Writing', 'writing', 'Writing and general-purpose AI assistants', 2),
  ('Design', 'design', 'Design, image, and creative AI tools', 3),
  ('Automation', 'automation', 'Workflow and automation tools', 4)
ON CONFLICT (slug) DO NOTHING;

